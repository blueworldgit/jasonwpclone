{
  "name": "worldpay/php-sdk",
  "description": "Worldpay PHP SDK",
  "license": "MIT",
  "authors": [
    {
      "name": "Worldpay"
    }
  ],
  "require": {
    "php": ">=7.4",
    "ext-curl": "*",
    "ext-json": "*",
    "ext-intl": "*"
  },
  "autoload": {
    "psr-4": {
      "Worldpay\\Api\\": "src/"
    }
  },
  "require-dev": {
    "phpunit/phpunit": "^9.6"
  },
  "autoload-dev": {
    "psr-4": {
      "Worldpay\\Api\\Tests\\": "tests/"
    },
    "files": [
      "tests/Providers/.env.php"
    ]
  }
}
